rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /events/{eventId} {
      allow read: if true;
      // Note: In production, write should be restricted to authenticated admins
      allow write: if true; 
    }
    match /bookings/{bookingId} {
      allow read, write: if true; 
    }
  }
}
